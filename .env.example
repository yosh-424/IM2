# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/library_visitor_system
# For MongoDB Atlas cloud, use:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/library_visitor_system

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
